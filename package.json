{
  "name": "website-starter",
  "version": "0.1.0",
  "private": false,
  "description": "A reusable Next.js marketing website starter with block variants, seed content, a typed dev panel, and a controller-driven theme system.",
  "license": "MIT",
  "author": "David Victor",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidvictor/website-starter.git"
  },
  "homepage": "https://github.com/davidvictor/website-starter",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check . && pnpm check:polish",
    "check:polish": "node scripts/check-polish.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:changed": "vitest run --changed origin/main",
    "audit:a11y": "node scripts/audit-a11y.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,json}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@paper-design/shaders": "^0.0.76",
    "@paper-design/shaders-react": "^0.0.76",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "leva": "^0.10.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.6",
    "react-resizable-panels": "^4.11.1",
    "recharts": "3.8.1",
    "shadcn": "^4.7.0",
    "shaders": "^2.5.124",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
