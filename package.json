{
  "name": "lookbook",
  "version": "0.1.0",
  "private": false,
  "description": "A Next.js base for moving from design direction to clickable page in one sitting. Ships with three style variants per block, a typed dev panel, and a controller-driven color system.",
  "license": "MIT",
  "author": "David Victor",
  "repository": {
    "type": "git",
    "url": "https://github.com/davidvictor/lookbook.git"
  },
  "homepage": "https://github.com/davidvictor/lookbook",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check . && pnpm check:polish",
    "check:polish": "node scripts/check-polish.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@paper-design/shaders": "^0.0.76",
    "@paper-design/shaders-react": "^0.0.76",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "leva": "^0.10.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.1",
    "recharts": "3.8.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
